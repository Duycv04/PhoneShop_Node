<section class="container page-head"><h1>So sánh sản phẩm</h1><p>Chọn sản phẩm bằng nút ⇄ trên card sản phẩm.</p></section><section class="container page-card"><% if(!products.length){ %><p>Chưa chọn sản phẩm để so sánh.</p><% } else { %><table class="table compare"><tr><th>Tiêu chí</th><% products.forEach(p=>{ %><th><%= p.productname %></th><% }) %></tr><tr><td>Ảnh</td><% products.forEach(p=>{ %><td><img class="compare-img" src="<%= p.imageurl || '/images/placeholder-phone.png' %>"></td><% }) %></tr><tr><td>Giá</td><% products.forEach(p=>{ %><td><%= format.money(p.finalprice || p.price) %></td><% }) %></tr><tr><td>Thương hiệu</td><% products.forEach(p=>{ %><td><%= p.brandname || '' %></td><% }) %></tr><tr><td>Đánh giá</td><% products.forEach(p=>{ %><td>★ <%= p.average_rating || 0 %></td><% }) %></tr></table><% } %></section>
