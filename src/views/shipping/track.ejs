<section class="container page-head"><h1>Tra cứu vận đơn</h1></section><section class="container page-card"><form method="get"><input name="trackingNumber" value="<%= trackingNumber || '' %>" placeholder="Mã vận đơn"><button class="btn primary">Tra cứu</button></form><% if(shipment){ %><div class="mini-card"><h2><%= shipment.providername || 'Đơn vị vận chuyển' %></h2><p>Mã: <b><%= shipment.trackingnumber %></b></p><p>Trạng thái: <b><%= shipment.status %></b></p><p>Địa chỉ: <%= shipment.shiptoaddress || '' %></p></div><% } %></section>
