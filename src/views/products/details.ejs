<section class="container product-detail">
  <div class="detail-gallery">
    <img class="main-img" src="<%= product.imageurl || '/images/placeholder-phone.png' %>" alt="<%= product.productname %>">
    <div class="thumbs"><% (product.images || []).forEach(img=>{ %><img src="<%= img.imageurl %>" alt=""><% }) %></div>
  </div>
  <div class="detail-info">
    <div class="meta"><%= product.brandname || 'PhoneShop' %> · <%= product.categoryname || '' %></div>
    <h1><%= product.productname %></h1>
    <div class="rating big-rating">★ <%= product.average_rating || 0 %> · <%= product.review_count || 0 %> đánh giá · <%= product.view_count || 0 %> lượt xem</div>
    <div class="detail-price"><%= format.money(product.finalprice || product.saleprice || product.price) %> <% if(Number(product.finalprice||product.saleprice||product.price)<Number(product.price)){ %><del><%= format.money(product.price) %></del><% } %></div>
    <p><%= product.description || 'Sản phẩm chính hãng, bảo hành rõ ràng.' %></p>
    <form class="buy-box" method="post" action="/cart/add/<%= product.productid %>"><input type="number" name="quantity" value="1" min="1"><button class="btn primary big">Thêm vào giỏ</button></form>
    <div class="quick-links"><a href="/installment?productId=<%= product.productid %>">Mua trả góp</a><a href="/tradein">Thu cũ đổi mới</a><a href="/warranty/create?productId=<%= product.productid %>">Bảo hành/đổi trả</a></div>
    <div class="spec-box"><h3>Thông số kỹ thuật</h3><% if((product.specs||[]).length){ product.specs.forEach(s=>{ %><div><span><%= s.specname %></span><b><%= s.specvalue %></b></div><% }) } else { %><p>Chưa có thông số.</p><% } %></div>
  </div>
</section>
<section class="container section two-columns">
  <div class="page-card"><h2>Đánh giá</h2><% (product.reviews||[]).forEach(r=>{ %><div class="review"><b>★ <%= r.rating %> - <%= r.fullname || 'Khách hàng' %></b><p><%= r.comment %></p></div><% }) %><% if(currentUser){ %><form method="post" action="/products/<%= product.productid %>/review"><select name="rating"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select><textarea name="comment" placeholder="Nhận xét của bạn"></textarea><button class="btn primary">Gửi đánh giá</button></form><% } %></div>
  <div class="page-card"><h2>Hỏi đáp sản phẩm</h2><% (product.questions||[]).forEach(q=>{ %><div class="review"><b><%= q.fullname || 'Khách hàng' %></b><p><%= q.question %></p><% if(q.answer){ %><p class="answer">Admin: <%= q.answer %></p><% } %></div><% }) %><% if(currentUser){ %><form method="post" action="/products/<%= product.productid %>/question"><textarea name="question" placeholder="Nhập câu hỏi..."></textarea><button class="btn primary">Gửi câu hỏi</button></form><% } %></div>
</section>
<section class="container section"><div class="section-head"><h2>Sản phẩm liên quan</h2></div><div class="product-grid"><% related.forEach(product=>{ %><%- include('../partials/product-card',{product}) %><% }) %></div></section>
