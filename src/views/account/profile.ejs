<section class="container page-head"><h1>Tài khoản của tôi</h1></section>
<section class="container two-columns"><form class="page-card" method="post" action="/account/profile"><h2>Thông tin cá nhân</h2><label>Họ tên</label><input name="fullname" value="<%= user.fullname %>"><label>Email</label><input value="<%= user.email %>" disabled><label>SĐT</label><input name="phone" value="<%= user.phone || '' %>"><label>Địa chỉ</label><textarea name="address"><%= user.address || '' %></textarea><button class="btn primary">Lưu</button></form><div class="page-card"><h2>Địa chỉ giao hàng</h2><% addresses.forEach(a=>{ %><div class="mini-card"><b><%= a.receivername %> - <%= a.phone %></b><p><%= a.address %></p></div><% }) %><form method="post" action="/account/address"><input name="receivername" placeholder="Người nhận"><input name="phone" placeholder="SĐT"><textarea name="address" placeholder="Địa chỉ"></textarea><label><input type="checkbox" name="isdefault"> Mặc định</label><button class="btn primary">Thêm địa chỉ</button></form></div></section>
