<section class="container page-head"><h1>Đơn hàng <%= order.ordercode %></h1><p>Trạng thái: <b><%= order.status %></b></p></section><section class="container two-columns"><div class="page-card"><h2>Sản phẩm</h2><table class="table"><% items.forEach(i=>{ %><tr><td class="table-product"><img src="<%= i.imageurl || '/images/placeholder-phone.png' %>"><%= i.productname %></td><td><%= i.quantity %></td><td><%= format.money(i.price) %></td></tr><% }) %></table><h3>Tổng: <%= format.money(order.totalamount) %></h3><% if(['Pending','Confirmed'].includes(order.status)){ %><form method="post" action="/orders/<%= order.orderid %>/cancel"><button class="btn danger">Hủy đơn</button></form><% } %></div><div class="page-card"><h2>Vận chuyển & thanh toán</h2><% shipments.forEach(s=>{ %><p><b><%= s.providername %></b> - <%= s.trackingnumber %> - <%= s.status %></p><% }) %><% payments.forEach(p=>{ %><p><b><%= p.paymentmethod %></b> - <%= format.money(p.amount) %> - <%= p.status %></p><% }) %><a href="/refund/create?orderId=<%= order.orderid %>">Yêu cầu hoàn tiền</a></div></section>
