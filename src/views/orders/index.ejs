<section class="container page-head"><h1>Đơn hàng của tôi</h1></section><section class="container page-card"><table class="table"><tr><th>Mã</th><th>Ngày</th><th>Tổng</th><th>Trạng thái</th><th></th></tr><% orders.forEach(o=>{ %><tr><td><%= o.ordercode %></td><td><%= format.datetime(o.createdat) %></td><td><%= format.money(o.totalamount) %></td><td><span class="status"><%= o.status %></span></td><td><a href="/orders/<%= o.orderid %>">Chi tiết</a></td></tr><% }) %></table></section>
