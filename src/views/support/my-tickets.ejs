<section class="container page-head"><h1>Ticket hỗ trợ</h1></section><section class="container page-card"><form method="get"><input name="email" value="<%= email || '' %>" placeholder="Nhập email để tra cứu"><button class="btn primary">Tra cứu</button></form><% tickets.forEach(t=>{ %><div class="mini-card"><b><%= t.subject %> - <%= t.status %></b><p><%= t.message %></p><% if(t.adminreply){ %><p class="answer">Admin: <%= t.adminreply %></p><% } %></div><% }) %></section>
