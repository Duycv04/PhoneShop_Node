<section class="container page-head"><h1>Trung tâm hỗ trợ</h1></section><section class="container two-columns"><form class="page-card" method="post" action="/support"><h2>Gửi yêu cầu hỗ trợ</h2><input name="fullname" placeholder="Họ tên" value="<%= currentUser?.fullname || '' %>" required><input name="email" type="email" placeholder="Email" value="<%= currentUser?.email || '' %>" required><input name="phone" placeholder="SĐT"><input name="subject" placeholder="Tiêu đề" required><textarea name="message" placeholder="Nội dung" required></textarea><button class="btn primary">Gửi hỗ trợ</button></form><div class="page-card"><h2>Dịch vụ nhanh</h2><a href="/shipping/track">Tra cứu vận đơn</a><a href="/support/warranty-policy">Chính sách bảo hành</a><a href="/chatbot">FAQ / Chatbot</a></div></section>
