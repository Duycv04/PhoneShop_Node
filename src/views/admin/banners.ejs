<section class="container page-head"><h1>Banner trang chủ</h1></section><section class="container admin-layout"><%- include('nav') %><div><form class="page-card" method="post"><input name="title" placeholder="Tiêu đề"><input name="subtitle" placeholder="Mô tả"><input name="imageurl" placeholder="Ảnh"><input name="targeturl" placeholder="Link"><input name="badgetext" placeholder="Badge"><input name="displayorder" placeholder="Thứ tự"><button class="btn primary">Thêm banner</button></form><div class="page-card"><table class="table"><% items.forEach(i=>{ %><tr><td><%= i.title %></td><td><%= i.targeturl %></td><td><%= i.isactive %></td></tr><% }) %></table></div></div></section>
