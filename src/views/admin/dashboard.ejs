<section class="container page-head"><h1>Admin Dashboard</h1><p>Quản trị PhoneShop bản Node.js.</p></section>
<section class="container admin-grid">
  <div class="stat"><span>Sản phẩm</span><b><%= stats.products %></b></div><div class="stat"><span>Đơn hàng</span><b><%= stats.orders %></b></div><div class="stat"><span>Khách hàng</span><b><%= stats.users %></b></div><div class="stat"><span>Doanh thu</span><b><%= format.money(revenue) %></b></div>
  <div class="stat"><span>Ticket</span><b><%= stats.support %></b></div><div class="stat"><span>Bảo hành</span><b><%= stats.warranty %></b></div><div class="stat"><span>Combo</span><b><%= stats.bundles %></b></div><div class="stat"><span>Bài viết</span><b><%= stats.news %></b></div>
</section>
<section class="container admin-layout"><%- include('nav') %><div class="page-card"><h2>Đơn hàng mới</h2><table class="table"><% latestOrders.forEach(o=>{ %><tr><td><%= o.ordercode %></td><td><%= o.fullname || '' %></td><td><%= format.money(o.totalamount) %></td><td><%= o.status %></td></tr><% }) %></table></div></section>
