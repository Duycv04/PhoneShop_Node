<section class="container page-head"><h1>Khuyến mãi sản phẩm</h1></section><section class="container admin-layout"><%- include('nav') %><div><form class="page-card" method="post"><select name="productid"><% products.forEach(p=>{ %><option value="<%= p.productid %>"><%= p.productname %></option><% }) %></select><input name="title" placeholder="Tên khuyến mãi"><input name="badgetext" placeholder="Badge"><input name="discountpercent" placeholder="% giảm"><input name="saleprice" placeholder="Giá sale"><input name="startat" type="datetime-local"><input name="endat" type="datetime-local"><button class="btn primary">Thêm</button></form><div class="page-card"><table class="table"><% items.forEach(i=>{ %><tr><td><%= i.productname %></td><td><%= i.title %></td><td><%= i.discountpercent || '' %>%</td><td><%= i.saleprice ? format.money(i.saleprice) : '' %></td></tr><% }) %></table></div></div></section>
