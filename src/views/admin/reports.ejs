<section class="container page-head"><h1>Báo cáo kinh doanh</h1></section><section class="container admin-layout"><%- include('nav') %><div class="two-columns"><div class="page-card"><h2>Doanh thu 14 ngày</h2><table class="table"><% revenueByDay.forEach(r=>{ %><tr><td><%= format.date(r.day) %></td><td><%= format.money(r.revenue) %></td><td><%= r.orders %> đơn</td></tr><% }) %></table></div><div class="page-card"><h2>Top bán chạy</h2><table class="table"><% topProducts.forEach(p=>{ %><tr><td><%= p.productname %></td><td><%= p.sold %></td></tr><% }) %></table><h2>Tồn kho thấp</h2><table class="table"><% lowStock.forEach(p=>{ %><tr><td><%= p.productname %></td><td><%= p.quantity %></td></tr><% }) %></table></div></div></section>
