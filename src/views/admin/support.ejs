<section class="container page-head"><h1>Ticket hỗ trợ</h1></section><section class="container admin-layout"><%- include('nav') %><div class="page-card"><% items.forEach(i=>{ %><div class="mini-card"><b><%= i.subject %> - <%= i.status %></b><p><%= i.fullname %> · <%= i.email %></p><p><%= i.message %></p><form method="post" action="/admin/support/<%= i.ticketid %>/reply"><textarea name="adminreply"><%= i.adminreply || '' %></textarea><button class="btn primary">Phản hồi</button></form></div><% }) %></div></section>
