<section class="container page-head"><h1>Quản lý đơn hàng</h1></section><section class="container admin-layout"><%- include('nav') %><div class="page-card"><table class="table"><% orders.forEach(o=>{ %><tr><td><%= o.ordercode %></td><td><%= o.fullname || '' %></td><td><%= format.money(o.totalamount) %></td><td><form method="post" action="/admin/orders/<%= o.orderid %>/status"><select name="status"><% ['Pending','Confirmed','Shipping','Completed','Cancelled'].forEach(s=>{ %><option <%= o.status===s?'selected':'' %>><%= s %></option><% }) %></select><button>Lưu</button></form></td></tr><% }) %></table></div></section>
