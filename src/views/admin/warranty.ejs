<section class="container page-head"><h1>Quản lý bảo hành/đổi trả</h1></section><section class="container admin-layout"><%- include('nav') %><div class="page-card"><% items.forEach(i=>{ %><div class="mini-card"><b><%= i.fullname %> - <%= i.productname || '' %></b><p><%= i.reason %></p><form method="post" action="/admin/warranty/<%= i.warrantyrequestid %>/status"><select name="status"><option>Pending</option><option>Processing</option><option>Approved</option><option>Rejected</option><option>Completed</option></select><textarea name="adminnote" placeholder="Ghi chú"><%= i.adminnote || '' %></textarea><button class="btn primary">Cập nhật</button></form></div><% }) %></div></section>
