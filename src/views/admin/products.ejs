<section class="container page-head"><h1>Quản lý sản phẩm</h1></section><section class="container admin-layout"><%- include('nav') %><div><form class="page-card" method="post"><h2>Thêm sản phẩm</h2><input name="productname" placeholder="Tên sản phẩm"><input name="price" placeholder="Giá"><input name="quantity" placeholder="Số lượng"><input name="imageurl" placeholder="/images/ip16.jpg"><select name="brandid"><option value="">Thương hiệu</option><% brands.forEach(b=>{ %><option value="<%= b.brandid %>"><%= b.brandname %></option><% }) %></select><select name="categoryid"><option value="">Danh mục</option><% categories.forEach(c=>{ %><option value="<%= c.categoryid %>"><%= c.categoryname %></option><% }) %></select><textarea name="description" placeholder="Mô tả"></textarea><button class="btn primary">Thêm</button></form><div class="page-card"><h2>Danh sách</h2><table class="table"><% products.forEach(p=>{ %><tr><td><%= p.productid %></td><td><%= p.productname %></td><td><%= format.money(p.price) %></td><td><%= p.quantity %></td><td><%= p.categoryname || '' %></td><td><form method="post" action="/admin/products/<%= p.productid %>/delete"><button>Ẩn</button></form></td></tr><% }) %></table></div></div></section>
