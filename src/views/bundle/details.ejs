<section class="container page-head"><h1><%= bundle?.bundlename || 'Combo' %></h1><p><%= bundle?.description || '' %></p></section><section class="container two-columns"><div class="page-card"><table class="table"><% items.forEach(i=>{ %><tr><td class="table-product"><img src="<%= i.imageurl || '/images/placeholder-phone.png' %>"><%= i.productname %></td><td>x<%= i.quantity %></td><td><%= format.money(i.price) %></td></tr><% }) %></table></div><div class="page-card"><h2>Giá combo</h2><div class="detail-price"><%= format.money(bundle?.bundleprice||0) %></div><form method="post" action="/bundle/<%= bundle?.bundleid %>/add"><button class="btn primary big">Thêm combo vào giỏ</button></form></div></section>
