<section class="container page-head"><h1>Đặt lịch nhận hàng</h1></section><section class="container page-card"><form method="post" action="/store/create-pickup"><input name="orderid" placeholder="Mã đơn hàng"><select name="branchid"><% branches.forEach(b=>{ %><option value="<%= b.branchid %>"><%= b.branchname %></option><% }) %></select><input type="date" name="appointmentdate"><select name="timeslot"><option>08:00-10:00</option><option>10:00-12:00</option><option>14:00-16:00</option><option>16:00-18:00</option></select><textarea name="note" placeholder="Ghi chú"></textarea><button class="btn primary">Đặt lịch</button></form></section>
