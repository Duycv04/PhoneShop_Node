<section class="container page-head"><h1>FAQ / Chatbot hỗ trợ nhanh</h1></section><section class="container two-columns"><form class="page-card" method="post" action="/chatbot/ask"><h2>Hỏi nhanh</h2><input name="q" value="<%= question %>" placeholder="Ví dụ: bảo hành, giao hàng, trả góp..."><button class="btn primary">Hỏi</button><% if(answer){ %><div class="answer-box"><b>Trả lời:</b><p><%= answer %></p></div><% } %></form><div class="page-card"><h2>Câu hỏi phổ biến</h2><% faqs.forEach(f=>{ %><details><summary><%= f.question %></summary><p><%= f.answer %></p></details><% }) %></div></section>
