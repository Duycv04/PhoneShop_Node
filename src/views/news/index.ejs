<section class="container page-head"><h1>Tin tức công nghệ</h1></section><section class="container card-grid"><% articles.forEach(a=>{ %><a class="page-card" href="/news/<%= a.slug || a.articleid %>"><span class="meta"><%= a.categoryname || 'Tin tức' %></span><h2><%= a.title %></h2><p><%= a.summary || '' %></p><small><%= format.date(a.publishedat || a.createdat) %> · <%= a.viewcount || 0 %> lượt xem</small></a><% }) %></section>
