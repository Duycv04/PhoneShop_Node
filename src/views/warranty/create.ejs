<section class="container page-head"><h1>Gửi yêu cầu bảo hành/đổi trả</h1></section><section class="container page-card"><form method="post" action="/warranty/create"><input name="orderid" value="<%= query.orderId || '' %>" placeholder="Mã đơn hàng"><select name="productid"><option value="">Chọn sản phẩm</option><% products.forEach(p=>{ %><option value="<%= p.productid %>" <%= String(query.productId||'')===String(p.productid)?'selected':'' %>><%= p.productname %></option><% }) %></select><select name="requesttype"><option>Warranty</option><option>Return</option><option>Exchange</option></select><textarea name="reason" placeholder="Mô tả vấn đề" required></textarea><button class="btn primary">Gửi yêu cầu</button></form></section>
