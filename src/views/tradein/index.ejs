<section class="container page-head"><h1>Thu cũ đổi mới</h1></section><section class="container two-columns"><form class="page-card" method="post" action="/tradein"><h2>Định giá máy cũ</h2><select name="targetproductid"><option value="">Sản phẩm muốn đổi sang</option><% products.forEach(p=>{ %><option value="<%= p.productid %>"><%= p.productname %></option><% }) %></select><input name="olddevicebrand" placeholder="Hãng máy cũ"><input name="olddevicemodel" placeholder="Model"><input name="imei" placeholder="IMEI"><select name="conditionlevel"><option value="Excellent">Đẹp</option><option value="Good">Tốt</option><option value="Average">Trung bình</option><option value="Broken">Lỗi</option></select><textarea name="customerdescription" placeholder="Mô tả tình trạng"></textarea><button class="btn primary">Gửi định giá</button></form><div class="page-card"><h2>Lịch sử</h2><% items.forEach(i=>{ %><div class="mini-card"><b><%= i.olddevicebrand %> <%= i.olddevicemodel %></b><p>Ước tính: <%= format.money(i.estimatedvalue) %> · <%= i.status %></p></div><% }) %></div></section>
