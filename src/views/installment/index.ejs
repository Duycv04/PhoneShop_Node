<section class="container page-head"><h1>Mua trả góp</h1><p>Chọn gói trả góp phù hợp và gửi hồ sơ xét duyệt.</p></section><section class="container card-grid"><% plans.forEach(p=>{ %><div class="page-card"><h2><%= p.planname %></h2><p><%= p.termmonths %> tháng · Lãi <%= p.interestpercent || 0 %>%</p></div><% }) %></section><section class="container page-card"><form method="post" action="/installment"><h2>Gửi hồ sơ nhanh</h2><input name="productid" placeholder="ID sản phẩm"><input name="productprice" placeholder="Giá sản phẩm"><input name="prepaidamount" placeholder="Trả trước"><input name="termmonths" placeholder="Số tháng" value="12"><input name="customerphone" placeholder="SĐT" required><button class="btn primary">Gửi hồ sơ</button></form></section>
