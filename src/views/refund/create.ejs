<section class="container page-head"><h1>Gửi yêu cầu hoàn tiền</h1></section><section class="container page-card"><% if(!order){ %><p>Không tìm thấy đơn hàng.</p><% } else { %><form method="post" action="/refund/create"><input type="hidden" name="orderid" value="<%= order.orderid %>"><p>Đơn hàng: <b><%= order.ordercode %></b></p><label>Số tiền</label><input name="amount" value="<%= order.totalamount %>"><label>Lý do</label><textarea name="reason" required></textarea><button class="btn primary">Gửi yêu cầu</button></form><% } %></section>
